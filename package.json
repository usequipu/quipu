{
  "name": "quipu_simple",
  "private": true,
  "version": "0.15.0",
  "description": "A web-based code editor with rich text, terminal, and git support",
  "author": {
    "name": "barelias",
    "email": "iagoelifa@gmail.com"
  },
  "homepage": "https://quipu.cc",
  "license": "MIT WITH Commons-Clause",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron": "wait-on tcp:5188 && cross-env VITE_DEV_SERVER_URL=http://localhost:5188 electron .",
    "electron:pack": "electron-builder",
    "start": "concurrently -k \"npm run dev\" \"npm run electron\"",
    "build:server": "bash scripts/build-server.sh",
    "build:release": "bash scripts/build-release.sh",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@phosphor-icons/react": "^2.1.10",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.23",
    "@tiptap/extension-bubble-menu": "^3.15.3",
    "@tiptap/extension-code-block-lowlight": "^3.22.1",
    "@tiptap/extension-highlight": "^3.15.3",
    "@tiptap/extension-image": "^3.15.3",
    "@tiptap/extension-placeholder": "^3.15.3",
    "@tiptap/extension-table": "^3.20.0",
    "@tiptap/extension-table-cell": "^3.20.0",
    "@tiptap/extension-table-header": "^3.20.0",
    "@tiptap/extension-table-row": "^3.20.0",
    "@tiptap/react": "^3.15.3",
    "@tiptap/starter-kit": "^3.15.3",
    "@tiptap/suggestion": "^3.22.3",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "adm-zip": "^0.5.17",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "highlight.js": "^11.11.1",
    "js-yaml": "^4.1.1",
    "lowlight": "^3.3.0",
    "node-pty": "^1.1.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.0",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.0",
    "react-resizable-panels": "^4.7.0",
    "semver": "^7.7.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tiptap-markdown": "^0.9.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@excalidraw/excalidraw": "^0.18.0",
    "@monaco-editor/react": "^4.7.0",
    "@types/dompurify": "^3.0.5",
    "@types/js-yaml": "^4.0.9",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@types/semver": "^7.7.1",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^39.2.7",
    "electron-builder": "^26.4.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "ansi-to-react": "^6.2.6",
    "dompurify": "^3.3.3",
    "jsdom": "^28.1.0",
    "marked": "^17.0.5",
    "mermaid": "^11.14.0",
    "react-pdf": "^10.4.1",
    "typescript": "^6.0.2",
    "vite": "^7.2.4",
    "vitest": "^4.0.18",
    "wait-on": "^9.0.3"
  },
  "build": {
    "appId": "com.quipu.editor",
    "productName": "Quipu",
    "extraMetadata": {
      "main": "electron/main-thin.cjs"
    },
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/main-thin.cjs",
      "electron/preload-thin.cjs",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "server/bin/${os}/",
        "to": "server/",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "msi",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "fileAssociations": [
        {
          "ext": "quipu",
          "name": "Quipu Document",
          "description": "Quipu rich text document",
          "role": "Editor"
        }
      ]
    },
    "msi": {
      "oneClick": false,
      "perMachine": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Quipu"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.developer-tools"
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Development"
    },
    "deb": {
      "depends": []
    }
  }
}
